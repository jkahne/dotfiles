# You probably want to change the [user] section here since you are not me.

[user]
	name = jkahne
	email = jkahne@hey.com

[github]
  user = jkahne

[alias]
  co = checkout
  ci = commit
  br = branch
  st = status
  ap = add -N --all -p
  unstage = reset HEAD
  standup = log --since yesterday
  uncommit = reset --soft HEAD~1
  graph = log --graph --topo-order --format='%C(auto)%h %<(3)%aN%d% s' --decorate=short --branches='*'
  l = log --oneline --decorate -20
  x = log --oneline --decorate --graph --all -20
  xx = log --oneline --decorate --graph --all
	sync = !git stash && git pull && git stash pop
#  ready = rebase -i @{u}
#  promote = !$ZSH/bin/git-promote
#  wtf     = !$ZSH/bin/git-wtf
#  rank-contributers = !$ZSH/bin/git-rank-contributers
#  count   = !git shortlog -sn

[color]
  branch = auto
  diff   = auto
  status = auto
	ui = true

[color "branch"]
  current = yellow reverse
  local   = yellow
  remote  = green

[color "diff"]
	meta = 11
	frag = magenta bold
	old = red bold
	new = green bold
	commit = yellow bold
	whitespace = red reverse

[color "status"]
  added     = yellow
  changed   = green
  untracked = cyan

[core]
  excludesfile = ~/.gitignore
  editor = vim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  features = side-by-side line-numbers decorations
  whitespace-error-style = 22 reverse

[delta "decorations"]
  commit-decoration-style = bold yellow box ul
  file-style = bold yellow ul
  file-decoration-style = none
  hunk-header-decoration-style = yellow box

[apply]
  whitespace = nowarn

[mergetool]
	keepBackup = false

[difftool]
  prompt = false

[help]
  autocorrect = 1
[credential]
  helper = osxkeychain
[push]
	default = simple
[diff]
	algorithm = patience
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[pull]
  rebase = true
[branch]
  autosetuprebase = always
[init]
  defaultBranch = main
